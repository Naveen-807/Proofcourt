# KeeperHub — Phase 6 wfb_ webhook-key execution + x402 USDC payment
# 1. Create an account at https://app.keeperhub.com
# 2. Create 3 workflows: proofcourt-trial, proofcourt-execute-mandate, proofcourt-settle
#    Each workflow gives you a wfb_ webhook key (shown once at creation).
# 3. For polling execution status, use an org-scoped kh_ key (Settings > Organisation API Keys).
#    The adapter uses GET /api/workflows/{workflowId}/executions and matches executionId.
# ProofCourt is real-only: missing wfb_ keys stop execution instead of creating receipts.
KEEPERHUB_API_URL="https://app.keeperhub.com"
KEEPERHUB_API_KEY=""                              # org-scoped kh_ key for GET status/logs
# Per-workflow wfb_ keys for POST /api/workflows/{id}/webhook execution
KEEPERHUB_TRIAL_KEY=""                            # wfb_ key for proofcourt-trial
KEEPERHUB_EXECUTE_KEY=""                          # wfb_ key for proofcourt-execute-mandate
KEEPERHUB_SETTLE_KEY=""                           # wfb_ key for proofcourt-settle
# Workflow IDs (copy from KeeperHub UI after creating workflows)
KEEPERHUB_TRIAL_WORKFLOW_ID=""
KEEPERHUB_EXECUTE_WORKFLOW_ID=""
KEEPERHUB_SETTLEMENT_WORKFLOW_ID=""
# Optional shared workflow ID when all phases intentionally use one workflow.
KEEPERHUB_WORKFLOW_ID=""
# MCP endpoint for agent-built workflows (set to true to enable runtime workflow creation)
KEEPERHUB_MCP_URL="https://app.keeperhub.com/mcp"
KEEPERHUB_BUILD_AT_RUNTIME="false"
