# 0G Compute — real serving-broker SDK integration
# Set these to enable live TEE-attested inference via qwen-2.5-7b-instruct
# ProofCourt is real-only: missing 0G Compute config stops verdict generation.
ZERO_G_PROVIDER_ADDRESS=""        # Provider wallet address from 0G Compute marketplace
ZERO_G_PROVIDER_ENDPOINT=""       # Optional metadata endpoint if SDK lookup is unavailable
ZERO_G_PROVIDER_MODEL="qwen-2.5-7b-instruct"
ZERO_G_PROVIDER_API_KEY=""        # Optional provider API key for single-provider HTTP mandate parsing
ZERO_G_CONTRACT_ADDRESS=""        # Optional: override default 0G serving contract
# 0G Router — preferred for server-side natural-language mandate parsing
ZERO_G_ROUTER_API_KEY=""
ZERO_G_ROUTER_API_URL="https://router-api-testnet.integratenetwork.work/v1"
